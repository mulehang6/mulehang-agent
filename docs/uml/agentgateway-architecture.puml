@startuml
title mulehang-agent 总体组件图（以 AgentGateway 为中心）

top to bottom direction
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultTextAlignment center

skinparam package {
  BorderColor #333333
}

skinparam component {
  BorderColor #444444
  BackgroundColor #F8F8F8
}

package "composeApp" as composeApp {
  component "MulehangDesktopApp\n根 Composable / 组装入口" as desktopApp
  component "ChatScreen\nUI 展示与输入" as chatScreen
  component "ChatWindowState\n窗口状态持有者" as chatWindowState
}

package "shared.application" as sharedApp {
  component "SendMessageUseCase\n发送消息用例" as sendMessageUseCase
  component "LoadAppSessionUseCase\n启动会话加载" as loadSessionUseCase
  component "AppSessionRepository\n会话仓库接口" as appSessionRepository
  component "DesktopAppSessionRepository\n桌面会话仓库实现" as desktopAppSessionRepository
  component "AppSessionSnapshot\n启动快照" as appSessionSnapshot
}

package "shared.agent" as sharedAgent {
  interface "AgentGateway\nrun(prompt, config)\n-> Flow<AgentStreamEvent>" as agentGateway
  component "KoogAgentGateway\nKoog 执行入口" as koogAgentGateway
  component "MulehangPromptExecutor\n按 providerType 构造 PromptExecutor" as promptExecutor
  component "AgentStreamEvent\nStarted / Delta / Completed / Failed" as agentStreamEvent
}

package "shared.config" as sharedConfig {
  component "ConfigProfile\n运行时最终配置" as configProfile
  component "DesktopSettingsRepository\n双层 settings 读取" as desktopSettingsRepository
  component "DesktopEnvironmentOverrides\n环境变量覆盖" as desktopEnvOverrides
  component "DesktopPathResolver\n配置路径解析" as desktopPathResolver
}

package "shared.state" as sharedState {
  component "ConversationState\n窗口会话状态" as conversationState
  component "ChatMessage\n消息模型" as chatMessage
  component "DesktopUiStateStore\n按项目记忆 profile" as desktopUiStateStore
}

package "Koog / LLM" as koogLlm {
  component "AIAgent" as aiAgent
  component "MultiLLMPromptExecutor" as multiExecutor
  component "OpenAILLMClient /\nAnthropicLLMClient" as llmClients
  component "OpenAIModels" as openAiModels
}

' 主链路：只保留最重要的调用流
desktopApp --> chatWindowState : 创建
desktopApp --> loadSessionUseCase : 启动加载 snapshot
chatScreen --> chatWindowState : 读写 UI 状态
chatWindowState --> sendMessageUseCase : send(message)
sendMessageUseCase --> agentGateway : run(prompt, profile)
sendMessageUseCase --> configProfile : 使用
agentGateway <|.. koogAgentGateway
koogAgentGateway --> promptExecutor : buildPromptExecutor(config)
koogAgentGateway --> aiAgent : 创建并 run(prompt)
koogAgentGateway --> openAiModels : 当前模型常量
koogAgentGateway --> agentStreamEvent : 输出事件流

' 配置与状态：作为侧向支撑，不再穿过主链路
desktopApp --> appSessionSnapshot : 传入初始快照
chatWindowState --> conversationState : 持有
conversationState --> chatMessage : 包含

loadSessionUseCase ..> appSessionRepository : 依赖
loadSessionUseCase ..> appSessionSnapshot : 输出
appSessionRepository <|.. desktopAppSessionRepository
appSessionRepository ..> configProfile : loadProfiles()
desktopAppSessionRepository ..> desktopUiStateStore : 记忆 profile
desktopAppSessionRepository ..> desktopSettingsRepository : loadProfiles()
desktopSettingsRepository ..> desktopEnvOverrides
desktopSettingsRepository ..> desktopPathResolver

promptExecutor --> multiExecutor
promptExecutor --> llmClients

' 布局约束，减少交叉
desktopApp -[hidden]down-> chatScreen
chatScreen -[hidden]down-> chatWindowState

sendMessageUseCase -[hidden]right-> agentGateway
agentGateway -[hidden]right-> koogAgentGateway
koogAgentGateway -[hidden]down-> promptExecutor
promptExecutor -[hidden]down-> multiExecutor

configProfile -[hidden]left-> agentGateway
conversationState -[hidden]left-> configProfile
desktopSettingsRepository -[hidden]down-> desktopEnvOverrides
desktopEnvOverrides -[hidden]right-> desktopPathResolver

legend right
== 说明 ==
实线：当前已存在的主要依赖或调用
虚线：设计上预留，但尚未完整接线

当前实现状态：
1. AgentGateway 是 shared 层对 Koog 的最小隔离边界
2. KoogAgentGateway 已能创建 AIAgent / PromptExecutor 并执行单轮 prompt
3. ChatWindowState.send() 已消费 Started / Delta / Completed / Failed
4. 真实主链路是 composeApp -> application -> agent -> Koog/LLM
endlegend

@enduml
